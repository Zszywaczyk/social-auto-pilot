{
	"name": "behancelikebot",
	"version": "1.0.0",
	"main": "main.js",
	"productName": "Behance Like Bot",
	"scripts": {
		"init": "npm run download:uBlock && npm run download:Chromium",
		"download:uBlock": "curl -o ./lib/uBlock.chromium.zip -L https://github.com/gorhill/uBlock/releases/download/1.45.2/uBlock0_1.45.2.chromium.zip && tar -xf ./lib/uBlock.chromium.zip -C ./lib/ && del .\\lib\\uBlock.chromium.zip",
		"download:Chromium": "curl -o ./lib/chrome-win.zip -L https://storage.googleapis.com/chromium-browser-snapshots/Win/1072391/chrome-win.zip && tar -xf ./lib/chrome-win.zip -C ./lib/ && del .\\lib\\chrome-win.zip",
		
		"ptr": "node index.js",
		"start": "electron .",
		"app:dist": "electron-builder",
		"package-mac": "electron-packager . --overwrite --platform=darwin --arch=x64 --icon=assets/icons/mac/icon.icns --prune=true --out=build",
		"package-win": "electron-packager . behancelikebot --overwrite --asar=true --platform=win32 --arch=ia32 --icon=assets/icons/win/icon.ico --prune=true --out=build --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName=\"Behance Like Bot\"",
		"package-linux": "electron-packager . behancelikebot --overwrite --asar=true --platform=linux --arch=x64 --icon=assets/icons/png/1024x1024.png --prune=true --out=build"
	},
	"dependencies": {
		"dotenv": "^16.0.3",
		"puppeteer": "^19.2.2"
	},
	"devDependencies": {
		"bootstrap": "^5.2.2",
		"electron": "^21.2.3",
		"electron-builder": "^23.6.0",
		"electron-packager": "^17.1.1"
	},
	"build": {
		"asarUnpack": [
			"lib/chrome-win/**/*",
			"lib/uBlock0.chromium/**/*"
		]
	}
}
